  [[ -z "$unit" ]] && unit="d"
  
  local exp_secs=0
  if [[ "$unit" = "d" ]]; then
    exp_secs=$(( val * 86400 ))
  elif [[ "$unit" = "h" ]]; then
    exp_secs=$(( val * 3600 ))
  elif [[ "$unit" = "m" ]]; then
    exp_secs=$(( val * 60 ))
  fi
  
  local exp_timestamp=$(( $(date +%s) + exp_secs ))
  mkdir -p /etc/UDPCustom/expiration
  echo "$exp_timestamp" > "/etc/UDPCustom/expiration/$1"
  
  local days_rounded=$(( (exp_secs + 86399) / 86400 ))
  valid=$(date '+%C%y-%m-%d' -d " +$days_rounded days")
  
  osl_v=$(openssl version | awk '{print $2}')
