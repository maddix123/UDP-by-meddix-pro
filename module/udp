  msg -bar
  data_user
  back

  print_center -ama "Type a Username from the list"
  msg -bar
  unset selection
  while [[ ${selection} = "" ]]; do
    msg -nazu "Please type a username: " && read selection
    del 1
  done

  [[ ${selection} = "0" ]] && return
  
  # Core Fix: Safe robust numeric selection checks, avoiding any formatting crashes
  if [[ "$selection" =~ ^[0-9]+$ ]]; then
    user_del="${active_users[$selection]}"
  else
    user_del="$selection"
  fi

  [[ -z $user_del ]] && {
    msg -verm "Error, Invalid User"
    msg -bar
    return 1
  }

  local found=false
  for au in "${active_users[@]}"; do
    if [[ "$au" = "$user_del" ]]; then
      found=true
      break
    fi
  done

  if [[ "$found" = "false" ]]; then
    msg -verm "Error, Invalid User"
    msg -bar
    sleep 3
    return 1
  fi

  msg -nama "   Username: $user_del >>>> "

  if [[ $(passwd --status $user_del | cut -d ' ' -f2) = "P" ]]; then
    pkill -u $user_del &>/dev/null
    droplim=$(droppids | grep -w "$user_del" | awk '{print $2}')
    kill -9 $droplim &>/dev/null
    usermod -L $user_del &>/dev/null
    sleep 2
    msg -verm2 "Blocked"
  else
    usermod -U $user_del
    sleep 2
    msg -verd "Unblocked"
  fi
  msg -bar
  sleep 3
}

#======== user remover =========

renew_user_fun() {
  local duration_input="$2"
  local val=$(echo "$duration_input" | grep -oE '^[0-9]+')
  local unit=$(echo "$duration_input" | grep -oE '[dhm]$')
  [[ -z "$unit" ]] && unit="d"
  
  local exp_secs=0
  if [[ "$unit" = "d" ]]; then
    exp_secs=$(( val * 86400 ))
  elif [[ "$unit" = "h" ]]; then
    exp_secs=$(( val * 3600 ))
  elif [[ "$unit" = "m" ]]; then
    exp_secs=$(( val * 60 ))
  fi
  
  # Core Fix: If the user ALREADY has a custom expiration file, we extend/renew starting FROM their future expiration timestamp
  # if their current timestamp is still in the future! Otherwise, we start from $(date +%s) (the current time).
  local exp_file="/etc/UDPCustom/expiration/$1"
  local start_timestamp=$(date +%s)
  
  if [[ -f "$exp_file" ]]; then
    local current_exp_ts=$(cat "$exp_file" | tr -d '\r\n')
    if [[ "$current_exp_ts" -gt "$start_timestamp" ]]; then
      start_timestamp="$current_exp_ts"
    fi
  fi
  
  local exp_timestamp=$(( start_timestamp + exp_secs ))
  mkdir -p /etc/UDPCustom/expiration
  echo "$exp_timestamp" > "$exp_file"
  
  local days_rounded=$(( (exp_timestamp - $(date +%s) + 86399) / 86400 ))
  valid=$(date '+%C%y-%m-%d' -d " +$days_rounded days")
  if chage -E $valid $1; then
    print_center -ama "Renewed User Successfully"
  else
    print_center -verm "Error, Renewal failed!"
  fi
}

